[13.83879, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mI found a blocking issue: there's a security\u001b[1Chook\u001b[1C(\u001b[38;5;153mssg hook eval\u001b[39m)\u001b[1Cthat\u001b[1Cprevents\u001b[1Cusing\u001b[1C\u001b[38;5;153mdangerouslySetInnerHTML\u001b[1C\u001b[39mwithout\u001b[1CHTML\u001b[1Csanitization.\u001b[1CThe\u001b[1Ccomment\u001b[1Ctells\u001b[1Cyou\u001b[1Cto\u001b[1Cuse\u001b[1Cit\r\u001b[2C\u001b[1Bunsanitized,\u001b[1Cbut\u001b[1Cthe\u001b[1Crepository's\u001b[1Csecurity\u001b[1Crules\u001b[1Crequire\u001b[1Csanitization\u001b[1Cwith\u001b[1CDOMPurify\u001b[1Cfirst.\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B  I\u001b[1Chave\u001b[1Ctwo\u001b[1Coptions:\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[14.037429, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  1. \u001b[1mFollow the hook's guidance\u001b[22m: Use \u001b[38;5;153mDOMPurify.sanitize(userHtml)\u001b[39m to safely render HTML                                                                                          \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[14.211725, "o", "\u001b]0;⠐ Replace TODO in app.tsx with JSX\u0007"]
[14.374736, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[7A1.\u001b[1C\u001b[1mFollow the hook's guidance\u001b[22m:\u001b[1CUse\u001b[1C\u001b[38;5;153mDOMPurify.sanitize(userHtml)\u001b[1C\u001b[39mto\u001b[1Csafely\u001b[1Crender\u001b[1CHTML\r\u001b[2C\u001b[1B2\u001b[2C\u001b[1mOverride the rule\u001b[22m: You'd need to disable the hook to use the\u001b[1Cexact unsanitized code\u001b[1Cfrom\u001b[1Cthe\u001b[1Ccomment\r\u001b[2B  Which would you prefer?                                                                                                                                                        \r\u001b[1B   \r\u001b[1B\u001b[38;5;174m✻\u001b[39m \u001b[38;5;174mGesticulating… \u001b[39m                                                                                                                                                                \r\u001b[2C\u001b[1B                                                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
